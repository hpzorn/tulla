            sh:path phase:preserves-mode ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select "SELECT ?this WHERE { ?this <http://impl-ralph.io/phase#producedBy> ?pb . FILTER(STRSTARTS(?pb, \"ep-\")) }" ] .
